      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "(sum(rate(http_request_duration_seconds_count{status=~\"[45].*\"}[1m])) or vector(0)) / (sum(rate(http_request_duration_seconds_count[1m])) or vector(1)) * 100",
          "legendFormat": "Error Rate %",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          },
          "unit": "percent"
