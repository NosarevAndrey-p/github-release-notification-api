<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Release notification</title>
  </head>
  <body style="<%= styles.body %>">
    <div style="<%= styles.container %>">
      <h2>🚀 New release detected</h2>
      <p>
        Repository:
        <span style="<%= styles.repo %>"><%= repo %></span>
      </p>
      <p>
        New version:
        <strong><%= newTag %></strong>
      </p>
      <p>
        Release details:
        <a href="<%= releaseUrl %>" target="_blank" rel="noopener noreferrer"
          >View release on GitHub</a
        >
      </p>
      <div>
        <a
          href="<%= unsubscribeUrl %>"
          style="<%= styles.btnBase + styles.unsubscribe %>"
          >Unsubscribe</a
        >
      </div>
      <p style="<%= styles.muted %>">
        You are receiving this because you subscribed to this repository.
      </p>
    </div>
  </body>
</html>
