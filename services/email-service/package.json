{
  "name": "email-service",
  "version": "1.0.0",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "tsx watch server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.build.json && node -e \"const fs=require('fs'); fs.mkdirSync('dist/src/templates', { recursive: true }); fs.readdirSync('src/templates').forEach(f => fs.copyFileSync('src/templates/' + f, 'dist/src/templates/' + f))\"",
    "lint": "eslint .",
    "test": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js"
  },
  "dependencies": {
    "@shared/logger": "*",
    "@shared/amqp": "*",
    "@shared/errors": "*",
    "amqplib": "^2.0.1",
    "dotenv": "^17.4.1",
    "ejs": "^3.1.10",
    "express": "^5.2.1",
    "nodemailer": "^6.10.0",
    "prom-client": "^15.1.3",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/nodemailer": "^6.4.17"
  }
}
