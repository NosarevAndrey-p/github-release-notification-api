{
  "name": "repo-subscriber",
  "version": "1.0.0",
  "description": " API that allows users to subscribe to email notifications about new releases of a chosen GitHub repository",
  "license": "ISC",
  "author": "Andrii Nosariev",
  "type": "module",
  "main": "server.js",
  "workspaces": [
    "services/*"
  ],
  "scripts": {
    "dev:subscription": "npm run dev -w services/subscription-service",
    "dev:notification": "npm run dev -w services/notification-service",
    "start:subscription": "npm run start -w services/subscription-service",
    "start:notification": "npm run start -w services/notification-service",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test -w services/subscription-service",
    "test:integration": "npm run test:integration -w services/subscription-service",
    "test:e2e": "npm run test:e2e -w services/subscription-service",
    "test:all": "npm run test && npm run test:integration && npm run test:e2e",
    "build-test": "npm run build && npm run test:all"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "jest": "^30.3.0",
    "jest-mock-extended": "^4.0.1",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "dependencies": {
    "dotenv": "^17.4.1",
    "ejs": "^5.0.2",
    "express": "^5.2.1",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "postgres-migrations": "^5.3.0",
    "prom-client": "^15.1.3",
    "winston": "^3.19.0"
  }
}
